{
  "name": "puente-workspace",
  "version": "0.1.0",
  "private": true,
  "description": "Monorepo workspace for puente — centralized Cloudflare Tunnel manager",
  "type": "module",
  "license": "MIT",
  "author": "Paul Barahona <johanpaulbarahona@gmail.com>",
  "homepage": "https://github.com/pauldvlp/puente#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pauldvlp/puente.git"
  },
  "bugs": {
    "url": "https://github.com/pauldvlp/puente/issues"
  },
  "packageManager": "pnpm@11.12.0",
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "dev": "pnpm --parallel --filter \"./apps/*\" dev",
    "dev:server": "pnpm --filter puente dev",
    "dev:web": "pnpm --filter @puente/web dev",
    "build": "pnpm --filter @puente/shared build && pnpm --filter @puente/web build && pnpm --filter puente build",
    "typecheck": "pnpm -r typecheck",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:live": "vitest run apps/server/src/modules/cloudflare/cloudflare.live.spec.ts",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "clean": "pnpm -r clean && rm -rf node_modules",
    "start": "pnpm --filter puente start",
    "sync:alias": "node scripts/sync-alias.mjs",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.6.1",
    "@commitlint/config-conventional": "^19.6.0",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.1",
    "@types/node": "^22.10.5",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.7.0",
    "husky": "^9.1.7",
    "prettier": "^3.9.5",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.64.0",
    "vitest": "^4.1.10"
  }
}
