{
  "name": "puente",
  "version": "0.1.0",
  "description": "Centralized, self-hosted manager for Cloudflare Tunnels across your machines — expose local ports on your own subdomains, orchestrate remote nodes over SSH.",
  "license": "MIT",
  "author": "pauldvlp <paulbh.dev@gmail.com>",
  "homepage": "https://github.com/pauldvlp/puente#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pauldvlp/puente.git",
    "directory": "apps/server"
  },
  "bugs": {
    "url": "https://github.com/pauldvlp/puente/issues"
  },
  "keywords": [
    "cloudflare",
    "cloudflare-tunnel",
    "cloudflared",
    "tunnel",
    "reverse-proxy",
    "self-hosted",
    "ssh",
    "homelab"
  ],
  "type": "commonjs",
  "bin": {
    "puente": "dist/cli.js"
  },
  "main": "dist/main.js",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20.10.0"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "dev": "nest start --watch",
    "build": "nest build && node scripts/prepare-dist.mjs",
    "start": "node dist/cli.js start",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "db:generate": "drizzle-kit generate",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.0",
    "@nestjs/core": "^11.1.0",
    "@nestjs/jwt": "^11.0.0",
    "@nestjs/platform-express": "^11.1.0",
    "@nestjs/serve-static": "^5.0.0",
    "better-sqlite3": "^12.0.0",
    "cloudflare": "^6.0.0",
    "commander": "^13.0.0",
    "drizzle-orm": "^0.45.0",
    "node-ssh": "^13.2.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "ssh-config": "^5.0.3",
    "ssh2": "^1.17.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@puente/shared": "workspace:*",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^22.10.5",
    "@types/ssh2": "^1.15.5",
    "drizzle-kit": "^0.31.0",
    "typescript": "^5.7.3"
  }
}
